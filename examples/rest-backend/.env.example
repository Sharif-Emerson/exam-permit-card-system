PORT=4000
APP_DB_PATH=./data/production.sqlite
SESSION_TTL_HOURS=12
CORS_ALLOWED_ORIGINS=http://localhost:5173
BOOTSTRAP_ADMIN_EMAIL=owner@yourdomain.com
BOOTSTRAP_ADMIN_PASSWORD=change-this-before-first-start
BOOTSTRAP_ADMIN_NAME=System Administrator
BOOTSTRAP_ADMIN_PHONE=
BOOTSTRAP_ADMIN_SCOPE=super-admin
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.example.com

# ── Email / SMTP configuration ──────────────────────────────────────────────
# Option A — Generic SMTP (recommended for custom domains, e.g. kiu.examcard.com)
# Works with any mail host: cPanel/Webmail, Google Workspace, Microsoft 365,
# Zoho Mail, SendGrid, Mailgun, Amazon SES, etc.
#
# SMTP_HOST=mail.kiu.examcard.com
# SMTP_PORT=587
# SMTP_SECURE=false          # true = SSL on port 465 | false = STARTTLS on 587
# SMTP_USER=admin@kiu.examcard.com
# SMTP_PASS=your-email-password
# EMAIL_FROM=KIU Exam Portal <admin@kiu.examcard.com>
#
# Option B — Gmail App Password (personal / G-Suite shortcut)
# Generate an App Password at: https://myaccount.google.com/apppasswords
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=your-16-char-app-password
#
# When neither option is configured, email notifications are silently skipped.
# Use Settings → Email in the admin panel to send a test email once configured.
# ────────────────────────────────────────────────────────────────────────────

# Optional: SIS / integration — batch create students (header X-Provision-Key)
# STUDENT_PROVISION_API_KEY=generate-a-long-random-secret
# Optional: SIS connector setup (activate when SIS endpoint is ready)
# SIS_PROVIDER=custom
# SIS_BASE_URL=https://sis.your-university.edu/api
# SIS_STUDENTS_PATH=/students
# SIS_AUTH_TYPE=bearer
# SIS_API_KEY=replace-with-your-sis-key
# SIS_TIMEOUT_MS=15000

# Optional: spreadsheet student import row cap (default 5000, max 20000)
# STUDENT_IMPORT_MAX_ROWS=5000
# Optional: assistant-admin department assignment by admin email
# Format: email=Department A|Department B,email2=Department C
# ASSISTANT_ADMIN_DEPARTMENTS=operations@example.com=Computer Science|Information Technology

# Optional: OIDC “Sign in with university” (students must already exist; match by email)
# OIDC_ISSUER=https://your-idp.example.com/realms/campus
# OIDC_CLIENT_ID=permit-portal
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:4000/auth/oidc/callback
# OIDC_SCOPE=openid email profile
# FRONTEND_ORIGIN=http://localhost:5173

# Optional: default campus stamped on API-created students
# DEFAULT_CAMPUS_ID=main-campus
# DEFAULT_CAMPUS_NAME=Main Campus

# Optional: HMAC integrity for public permit JSON (≥16 chars). Set in production for invigilator verification via GET /permits/verify/:token?integrity=...
# PERMIT_INTEGRITY_SECRET=replace-with-long-random-secret

# Optional: rate limits (abuse protection on login, password reset, public permit URLs)
# RATE_LIMIT_LOGIN_MAX=40
# RATE_LIMIT_RESET_PASSWORD_MAX=10
# RATE_LIMIT_PERMIT_PUBLIC_MAX=180